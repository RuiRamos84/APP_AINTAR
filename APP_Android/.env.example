# ========================================
# AINTAR MOBILE - Variáveis de Ambiente
# ========================================
# Copiar para .env e preencher com os valores reais

EXPO_PUBLIC_API_BASE_URL=http://localhost:5000/api/v1
EXPO_PUBLIC_WS_URL=http://localhost:5000
EXPO_PUBLIC_NODE_ENV=development
EXPO_PUBLIC_APP_TITLE=AINTAR APP

# Modelos de reconhecimento facial (@vladmandic/face-api) — ficheiros estáticos já
# publicados pelo frontend-v2, reutilizados pela app para o registo/verificação de ponto.
EXPO_PUBLIC_FACE_MODELS_URL=https://app.aintar.pt/v2/models/face-api
